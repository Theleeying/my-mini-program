<!--pages/lostfound/publish/publish.wxml — 发布失物/招领信息-->
<view class="page-publish">

  <!-- 类型选择 -->
  <view class="form-section card">
    <view class="form-label">发布类型</view>
    <view class="type-selector">
      <view
        class="type-item {{type === 'lost' ? 'active' : ''}}"
        data-type="lost"
        bindtap="switchType"
      >
        <text>寻失物</text>
      </view>
      <view
        class="type-item {{type === 'found' ? 'active' : ''}}"
        data-type="found"
        bindtap="switchType"
      >
        <text>招领</text>
      </view>
    </view>
  </view>

  <!-- 标题 -->
  <view class="form-section card">
    <view class="form-label">标题 <text class="required">*</text></view>
    <input class="form-input" placeholder="请输入标题" value="{{title}}" bindinput="onTitleInput" maxlength="50" />
  </view>

  <!-- 分类 -->
  <view class="form-section card">
    <view class="form-label">分类</view>
    <view class="category-selector">
      <view
        wx:for="{{categories}}"
        wx:key="*this"
        class="category-item {{category === item ? 'active' : ''}}"
        data-category="{{item}}"
        bindtap="selectCategory"
      >
        {{item}}
      </view>
    </view>
  </view>

  <!-- 详细描述 -->
  <view class="form-section card">
    <view class="form-label">详细描述 <text class="required">*</text></view>
    <textarea class="form-textarea" placeholder="请详细描述物品特征、丢失/发现时间地点等信息" value="{{description}}" bindinput="onDescInput" maxlength="500" />
    <text class="char-count">{{description.length}}/500</text>
  </view>

  <!-- 上传图片 -->
  <view class="form-section card">
    <view class="form-label">上传图片</view>
    <view class="image-uploader">
      <view class="image-item" wx:for="{{images}}" wx:key="index">
        <image class="uploaded-image" src="{{item}}" mode="aspectFill" bindtap="previewImage" data-index="{{index}}" />
        <view class="delete-btn" bindtap="deleteImage" data-index="{{index}}">×</view>
      </view>
      <view class="upload-btn" wx:if="{{uploadCount < maxUploadCount}}" bindtap="chooseImage">
        <text class="upload-icon">+</text>
        <text class="upload-text">上传图片</text>
      </view>
    </view>
  </view>

  <!-- 联系方式 -->
  <view class="form-section card">
    <view class="form-label">联系方式 <text class="required">*</text></view>
    <input class="form-input" placeholder="请输入手机号或微信号" value="{{contactInfo}}" bindinput="onContactInfoInput" maxlength="50" />
  </view>

  <!-- 地点 -->
  <view class="form-section card">
    <view class="form-label">地点</view>
    <input class="form-input" placeholder="请输入丢失/发现地点" value="{{location}}" bindinput="onLocationInput" />
  </view>

  <!-- 提交按钮 -->
  <view class="submit-section">
    <button class="btn-primary submit-btn" bindtap="submitForm" disabled="{{submitting}}">
      {{submitting ? '发布中...' : '确认发布'}}
    </button>
  </view>
</view>
