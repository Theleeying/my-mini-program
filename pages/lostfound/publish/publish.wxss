/** pages/lostfound/publish/publish.wxss — 发布失物/招领信息样式 **/

.page-publish {
  min-height: 100vh;
  padding: 20rpx;
  padding-bottom: 120rpx;
}

.form-section {
  margin-bottom: 20rpx;
}

.form-label {
  font-size: 28rpx;
  font-weight: 600;
  color: var(--color-text);
  margin-bottom: 20rpx;
}

.required {
  color: var(--color-danger);
}

/* ===== 类型选择 ===== */
.type-selector {
  display: flex;
  gap: 20rpx;
}

.type-item {
  flex: 1;
  height: 80rpx;
  line-height: 80rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg);
  border-radius: 12rpx;
  border: 2rpx solid var(--color-border);
}

.type-item.active {
  color: var(--color-primary);
  background-color: #E8F5E9;
  border-color: var(--color-primary);
}

/* ===== 表单输入 ===== */
.form-input {
  width: 100%;
  height: 80rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.form-textarea {
  width: 100%;
  height: 200rpx;
  background-color: var(--color-bg);
  border-radius: 12rpx;
  padding: 24rpx;
  font-size: 28rpx;
  color: var(--color-text);
  box-sizing: border-box;
}

.char-count {
  display: block;
  text-align: right;
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 10rpx;
}

/* ===== 分类选择 ===== */
.category-selector {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.category-item {
  padding: 12rpx 30rpx;
  font-size: 26rpx;
  color: var(--color-text-secondary);
  background-color: var(--color-bg);
  border-radius: 30rpx;
}

.category-item.active {
  color: var(--color-white);
  background-color: var(--color-primary);
}

/* ===== 图片上传 ===== */
.image-uploader {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.image-item {
  position: relative;
  width: 180rpx;
  height: 180rpx;
}

.uploaded-image {
  width: 100%;
  height: 100%;
  border-radius: 12rpx;
}

.delete-btn {
  position: absolute;
  top: -12rpx;
  right: -12rpx;
  width: 40rpx;
  height: 40rpx;
  line-height: 40rpx;
  text-align: center;
  background-color: rgba(0, 0, 0, 0.5);
  color: var(--color-white);
  border-radius: 50%;
  font-size: 28rpx;
}

.upload-btn {
  width: 180rpx;
  height: 180rpx;
  border: 2rpx dashed var(--color-border);
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
}

.upload-icon {
  font-size: 48rpx;
  color: var(--color-text-light);
}

.upload-text {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 8rpx;
}

/* ===== 提交按钮 ===== */
.submit-section {
  padding: 20rpx 0;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  font-size: 32rpx;
  border-radius: 44rpx;
}

.submit-btn[disabled] {
  opacity: 0.6;
}
