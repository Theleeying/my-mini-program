/** pages/user/my-publish/my-publish.wxss **/

.page-my-publish {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* 切换栏 */
.tab-bar {
  display: flex;
  background-color: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 28rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  position: relative;
}

.tab-active {
  color: var(--color-primary);
  font-weight: 600;
}

.tab-active::after {
  content: '';
  position: absolute;
  bottom: 0;
  left: 50%;
  transform: translateX(-50%);
  width: 60rpx;
  height: 4rpx;
  background-color: var(--color-primary);
  border-radius: 2rpx;
}

/* 列表 */
.publish-list {
  padding: 20rpx;
}

.publish-item {
  margin-bottom: 16rpx;
}

.publish-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.publish-thumb-placeholder {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 40rpx;
}

.publish-info {
  min-width: 0;
}

.publish-title {
  font-size: 30rpx;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.publish-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.publish-meta {
  margin-top: 10rpx;
}

.publish-status {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-active {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.status-done {
  background-color: #F5F5F5;
  color: #999;
}

.publish-time {
  font-size: 22rpx;
  color: var(--color-text-light);
}
