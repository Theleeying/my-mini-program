<!--pages/user/my-favorites/my-favorites.wxml — 我的收藏-->
<view class="page-my-favorites">

  <!-- 切换栏 -->
  <view class="tab-bar">
    <view
      wx:for="{{tabs}}"
      wx:key="*this"
      class="tab-item {{activeTab === index ? 'tab-active' : ''}}"
      data-index="{{index}}"
      bindtap="onTabChange"
    >
      {{item}}
    </view>
  </view>

  <!-- 加载中 -->
  <view wx:if="{{loading}}" class="empty-state">
    <text>加载中...</text>
  </view>

  <!-- 空状态 -->
  <view wx:elif="{{list.length === 0}}" class="empty-state">
    <text>{{activeTab === 0 ? '📦' : '🎯'}}</text>
    <text style="margin-top: 20rpx;">暂无收藏</text>
  </view>

  <!-- 列表 -->
  <view wx:else class="fav-list">
    <view
      wx:for="{{list}}"
      wx:key="_id"
      class="fav-item card"
      data-id="{{item._id}}"
      bindtap="onItemTap"
    >
      <view class="flex-row">
        <!-- 缩略图 -->
        <image
          wx:if="{{item.images && item.images.length}}"
          class="fav-thumb"
          src="{{item.images[0]}}"
          mode="aspectFill"
        />
        <view wx:else class="fav-thumb-placeholder">
          <text>{{activeTab === 0 ? '📦' : '🎯'}}</text>
        </view>

        <view class="fav-info flex-1">
          <text class="fav-title">{{item.title}}</text>
          <text class="fav-desc">{{item.description || ''}}</text>
          <view class="flex-between" style="margin-top: 10rpx;">
            <text wx:if="{{activeTab === 0 && item.price}}" class="fav-price">¥{{item.price}}</text>
            <text wx:if="{{activeTab === 1}}" class="fav-status {{item.status === 'active' ? 'status-active' : 'status-done'}}">
              {{item.status === 'resolved' ? '已解决' : '进行中'}}
            </text>
          </view>
        </view>

        <view class="fav-actions">
          <view class="btn-unfav" data-id="{{item._id}}" catchtap="onUnfavorite">取消</view>
        </view>
      </view>
    </view>
  </view>

</view>
