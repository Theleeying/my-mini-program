/** pages/user/my-favorites/my-favorites.wxss **/

.page-my-favorites {
  min-height: 100vh;
  background-color: var(--color-bg);
}

.fav-list {
  padding: 20rpx;
}

.fav-item {
  margin-bottom: 16rpx;
}

.fav-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.fav-thumb-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 44rpx;
}

.fav-info {
  min-width: 0;
}

.fav-title {
  font-size: 30rpx;
  font-weight: 500;
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  display: block;
  margin-top: 6rpx;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.fav-price {
  font-size: 32rpx;
  color: var(--color-danger);
  font-weight: 600;
}

.fav-actions {
  flex-shrink: 0;
  margin-left: 16rpx;
}

.btn-unfav {
  font-size: 24rpx;
  color: var(--color-text-light);
  padding: 10rpx 20rpx;
  border: 1rpx solid var(--color-border);
  border-radius: 8rpx;
}

/* ===== 顶部 tab 切换栏 ===== */
.tab-bar {
  display: flex;
  background: var(--color-white);
  border-bottom: 1rpx solid var(--color-border);
  padding: 0 30rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 26rpx 0;
  font-size: 28rpx;
  color: var(--color-text-secondary);
  border-bottom: 4rpx solid transparent;
  transition: all 0.2s;
}

.tab-active {
  color: var(--color-primary);
  border-bottom-color: var(--color-primary);
  font-weight: 600;
}

/* ===== 失物状态标签 ===== */
.fav-status {
  font-size: 24rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
}

.status-active {
  background-color: #E8F5E9;
  color: #4CAF50;
}

.status-done {
  background-color: #F5F5F5;
  color: #9E9E9E;
}
