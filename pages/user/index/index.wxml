<!--pages/user/index/index.wxml — 个人中心-->
<view class="page-user">

  <!-- 头部用户信息区 -->
  <view class="user-header">
    <!-- 已登录状态 -->
    <view wx:if="{{hasLogin}}" class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="cover" />
      <view class="user-text">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="uid">欢迎回来</text>
      </view>
    </view>

    <!-- 未登录：一键授权按钮 -->
    <button wx:else class="wechat-login-btn" open-type="getUserInfo" bindgetuserinfo="onWechatAuth">
      <image class="avatar-default" src="/images/default-avatar.png" mode="cover" />
      <view class="user-text">
        <text class="login-tip">点击微信授权登录</text>
        <text class="login-desc">授权获取微信头像和昵称</text>
      </view>
      <text class="arrow">›</text>
    </button>
  </view>

  <!-- 数据统计卡片 -->
  <view wx:if="{{hasLogin}}" class="stats-row">
    <view class="stats-item" bindtap="onMenuTap" data-url="/pages/user/my-publish/my-publish">
      <text class="stats-num">{{stats.publishCount}}</text>
      <text class="stats-label">已发布</text>
    </view>
    <view class="stats-divider"></view>
    <view class="stats-item" bindtap="onMenuTap" data-url="/pages/user/my-favorites/my-favorites">
      <text class="stats-num">{{stats.favoriteCount}}</text>
      <text class="stats-label">已收藏</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view
      wx:for="{{menuList}}"
      wx:key="title"
      class="menu-item list-item"
      data-url="{{item.url}}"
      bindtap="onMenuTap"
    >
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <view class="menu-text">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

</view>
