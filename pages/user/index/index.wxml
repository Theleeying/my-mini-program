<!--pages/user/index/index.wxml — 个人中心-->
<view class="page-user">

  <!-- 头部用户信息区 -->
  <view class="user-header">
    <!-- 已登录状态 -->
    <view wx:if="{{hasLogin}}" class="user-info">
      <image class="avatar" src="{{userInfo.avatarUrl}}" mode="cover" />
      <view class="user-text">
        <text class="nickname">{{userInfo.nickName}}</text>
        <text class="uid">欢迎回来</text>
      </view>
    </view>

    <!-- 未登录状态 -->
    <view wx:else class="user-login" bindtap="showLoginModal">
      <image class="avatar-default" src="/images/default-avatar.png" mode="cover" />
      <view class="user-text">
        <text class="login-tip">点击登录</text>
        <text class="login-desc">授权微信信息，畅享校园服务</text>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 功能菜单 -->
  <view class="menu-section">
    <view
      wx:for="{{menuList}}"
      wx:key="title"
      class="menu-item list-item"
      data-url="{{item.url}}"
      bindtap="onMenuTap"
    >
      <view class="menu-left">
        <text class="menu-icon">{{item.icon}}</text>
        <view class="menu-text">
          <text class="menu-title">{{item.title}}</text>
          <text class="menu-desc">{{item.desc}}</text>
        </view>
      </view>
      <text class="arrow">›</text>
    </view>
  </view>

  <!-- 登录授权弹窗 -->
  <view wx:if="{{showModal}}" class="modal-mask" bindtap="hideLoginModal"></view>
  <view wx:if="{{showModal}}" class="login-modal">
    <view class="modal-header">
      <text class="modal-title">微信授权登录</text>
      <text class="modal-close" bindtap="hideLoginModal">✕</text>
    </view>

    <view class="modal-body">
      <text class="modal-desc">授权获取你的微信头像和昵称，用于校内展示</text>

      <!-- 首选：getUserInfo 按钮，触发微信原生授权弹窗 -->
      <button
        class="btn-wechat-login"
        open-type="getUserInfo"
        bindgetuserinfo="onWechatAuth"
      >
        <text class="wechat-icon">🟢</text>
        <text>微信一键登录</text>
      </button>

      <text class="modal-divider">—— 或其他方式 ——</text>

      <view class="manual-section">
        <text class="manual-label">头像</text>
        <button class="avatar-picker-btn" open-type="chooseAvatar" bindchooseavatar="onChooseAvatar">
          <image
            class="avatar-preview"
            src="{{tempAvatarUrl || '/images/default-avatar.png'}}"
            mode="cover"
          />
          <text class="avatar-picker-tip">点击选择</text>
        </button>
      </view>

      <view class="manual-section">
        <text class="manual-label">昵称</text>
        <input
          class="nickname-field"
          type="nickname"
          placeholder="请输入昵称"
          value="{{tempNickName}}"
          bindinput="onNicknameInput"
        />
      </view>
    </view>

    <view class="modal-footer">
      <button class="btn-confirm" bindtap="onManualLogin" loading="{{saving}}">确认登录</button>
    </view>
  </view>

</view>
