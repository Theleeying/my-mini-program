/** pages/user/index/index.wxss — 个人中心样式 **/

.page-user {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* ===== 头部 ===== */
.user-header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 60rpx 30rpx 50rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 24rpx;
}

.user-text {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-white);
  display: block;
}

.uid {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
  display: block;
}

/* ===== 未登录区域 ===== */
.user-login-area {
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

/* 头像按钮 - 无默认button样式 */
.avatar-btn {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
  line-height: 1;
}

.avatar-btn::after {
  border: none;
}

.avatar-default {
  width: 130rpx;
  height: 130rpx;
  border-radius: 50%;
  border: 3rpx dashed rgba(255,255,255,0.6);
  background-color: rgba(255,255,255,0.2);
}

.avatar-tip {
  font-size: 22rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 10rpx;
  display: block;
  text-align: center;
}

/* 昵称输入行 */
.nickname-row {
  width: 100%;
  display: flex;
  justify-content: center;
  margin-top: 24rpx;
}

.nickname-input {
  width: 400rpx;
  height: 70rpx;
  line-height: 70rpx;
  background: rgba(255,255,255,0.9);
  border-radius: 35rpx;
  text-align: center;
  font-size: 28rpx;
  color: var(--color-text);
  padding: 0 30rpx;
}

/* 登录按钮 */
.login-btn {
  width: 400rpx;
  height: 76rpx;
  line-height: 76rpx;
  background: #ffffff;
  color: var(--color-primary);
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 38rpx;
  margin-top: 24rpx;
  border: none;
  padding: 0;
  text-align: center;
}

.login-btn::after {
  border: none;
}

.login-btn[loading] {
  opacity: 0.7;
}

.login-notice {
  font-size: 22rpx;
  color: rgba(255,255,255,0.6);
  margin-top: 14rpx;
}

/* ===== 菜单 ===== */
.menu-section {
  margin-top: 20rpx;
  background-color: var(--color-white);
  border-radius: 16rpx 16rpx 0 0;
  overflow: hidden;
}

.menu-item {
  padding: 30rpx 24rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  color: var(--color-text);
}

.menu-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 4rpx;
}
