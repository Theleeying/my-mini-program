/** pages/user/index/index.wxss — 个人中心样式 **/

.page-user {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* ===== 头部 ===== */
.user-header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 60rpx 30rpx 50rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

/* 微信一键登录按钮 - 去button默认样式 */
.wechat-login-btn {
  display: flex;
  align-items: center;
  width: 100%;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  text-align: left;
  line-height: 1;
}

.wechat-login-btn::after {
  border: none;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 24rpx;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255,255,255,0.3);
  margin-right: 24rpx;
}

.user-text {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-white);
  display: block;
}

.login-tip {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--color-white);
  display: block;
}

.uid {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
  display: block;
}

.user-header .arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.7);
}

/* ===== 数据统计卡片 ===== */
.stats-row {
  display: flex;
  margin: -30rpx 24rpx 0;
  padding: 30rpx 0;
  background: var(--color-white);
  border-radius: 16rpx;
  box-shadow: 0 4rpx 20rpx rgba(0,0,0,0.06);
}

.stats-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 10rpx 0;
}

.stats-num {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--color-primary);
}

.stats-label {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 6rpx;
}

.stats-divider {
  width: 1rpx;
  background: var(--color-border);
}

/* ===== 菜单 ===== */
.menu-section {
  margin-top: 20rpx;
  background-color: var(--color-white);
  border-radius: 16rpx 16rpx 0 0;
  overflow: hidden;
}

.menu-item {
  padding: 30rpx 24rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
  width: 48rpx;
  text-align: center;
  line-height: 1;
}

.menu-title {
  flex: 1;
  font-size: 30rpx;
  color: var(--color-text);
  line-height: 1;
}

.menu-item .arrow {
  font-size: 36rpx;
  color: #ccc;
}
