/** pages/user/index/index.wxss — 个人中心样式 **/

.page-user {
  min-height: 100vh;
  background-color: var(--color-bg);
}

/* ===== 头部 ===== */
.user-header {
  background: linear-gradient(135deg, #4CAF50, #66BB6A);
  padding: 60rpx 30rpx 50rpx;
}

.user-info {
  display: flex;
  align-items: center;
}

.user-login {
  display: flex;
  align-items: center;
}

.avatar {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  border: 4rpx solid rgba(255,255,255,0.5);
  margin-right: 24rpx;
}

.avatar-default {
  width: 120rpx;
  height: 120rpx;
  border-radius: 50%;
  background-color: rgba(255,255,255,0.3);
  margin-right: 24rpx;
}

.user-text {
  flex: 1;
}

.nickname {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-white);
  display: block;
}

.login-tip {
  font-size: 36rpx;
  font-weight: 600;
  color: var(--color-white);
  display: block;
}

.uid {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
}

.login-desc {
  font-size: 24rpx;
  color: rgba(255,255,255,0.8);
  margin-top: 6rpx;
  display: block;
}

.arrow {
  font-size: 40rpx;
  color: rgba(255,255,255,0.7);
}

/* ===== 菜单 ===== */
.menu-section {
  margin-top: 20rpx;
  background-color: var(--color-white);
  border-radius: 16rpx 16rpx 0 0;
  overflow: hidden;
}

.menu-item {
  padding: 30rpx 24rpx;
}

.menu-left {
  display: flex;
  align-items: center;
  flex: 1;
}

.menu-icon {
  font-size: 40rpx;
  margin-right: 20rpx;
}

.menu-text {
  display: flex;
  flex-direction: column;
}

.menu-title {
  font-size: 30rpx;
  color: var(--color-text);
}

.menu-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 4rpx;
}

/* ===== 登录弹窗 ===== */
.modal-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0,0,0,0.5);
  z-index: 1000;
}

.login-modal {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1001;
  padding: 40rpx 40rpx 60rpx;
  animation: slideUp 0.3s ease;
}

@keyframes slideUp {
  from { transform: translateY(100%); }
  to { transform: translateY(0); }
}

.modal-header {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 30rpx;
}

.modal-title {
  font-size: 36rpx;
  font-weight: 700;
  color: var(--color-text);
}

.modal-close {
  font-size: 36rpx;
  color: var(--color-text-light);
  padding: 10rpx;
}

.modal-body {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.modal-desc {
  font-size: 26rpx;
  color: var(--color-text-light);
  margin-bottom: 36rpx;
  text-align: center;
}

/* 微信一键登录按钮 */
.btn-wechat-login {
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  background: #07C160;
  color: #fff;
  font-size: 32rpx;
  font-weight: 600;
  border-radius: 48rpx;
  border: none;
  display: flex;
  align-items: center;
  justify-content: center;
  margin-bottom: 30rpx;
  padding: 0;
}

.btn-wechat-login::after {
  border: none;
}

.wechat-icon {
  font-size: 36rpx;
  margin-right: 12rpx;
}

/* 分割线 */
.modal-divider {
  font-size: 24rpx;
  color: #ccc;
  margin-bottom: 30rpx;
}

/* 手动填写区 */
.manual-section {
  width: 100%;
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.manual-label {
  width: 100rpx;
  font-size: 28rpx;
  color: var(--color-text);
  flex-shrink: 0;
}

.avatar-picker-btn {
  width: 80rpx;
  height: 80rpx;
  padding: 0;
  margin: 0;
  background: transparent;
  border: none;
  position: relative;
  border-radius: 50%;
  overflow: hidden;
}

.avatar-picker-btn::after {
  border: none;
}

.avatar-preview {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  border: 2rpx dashed #ccc;
}

.avatar-picker-tip {
  position: absolute;
  bottom: -6rpx;
  left: 50%;
  transform: translateX(-50%);
  font-size: 18rpx;
  color: var(--color-primary);
  background: #fff;
  padding: 0 6rpx;
}

.nickname-field {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  background: var(--color-bg);
  border-radius: 12rpx;
  padding: 0 20rpx;
  font-size: 28rpx;
  color: var(--color-text);
}

/* 底部确认按钮 */
.modal-footer {
  margin-top: 40rpx;
}

.btn-confirm {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: var(--color-primary);
  color: #fff;
  font-size: 30rpx;
  font-weight: 600;
  border-radius: 44rpx;
  border: none;
  padding: 0;
  text-align: center;
}

.btn-confirm::after {
  border: none;
}

.btn-confirm[loading] {
  opacity: 0.7;
}

/* 适配 iPhone X 底部安全区 */
@supports (bottom: env(safe-area-inset-bottom)) {
  .login-modal {
    padding-bottom: calc(60rpx + env(safe-area-inset-bottom));
  }
}
