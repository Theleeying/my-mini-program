/** pages/common/announcement-detail/announcement-detail.wxss — 公告详情样式 **/

.page-announcement {
  min-height: 100vh;
  background-color: var(--color-white);
}

.cover-img {
  width: 100%;
  height: 420rpx;
}

.title-section {
  padding: 36rpx 30rpx 24rpx;
  border-bottom: 1rpx solid var(--color-border);
}

.title {
  font-size: 38rpx;
  font-weight: 700;
  color: var(--color-text);
  line-height: 1.5;
  display: block;
}

.time {
  font-size: 24rpx;
  color: var(--color-text-light);
  margin-top: 16rpx;
  display: block;
}

.content-section {
  padding: 30rpx;
}

.content {
  font-size: 30rpx;
  color: var(--color-text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
  word-break: break-all;
}
