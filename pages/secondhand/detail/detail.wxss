/* 商品详情页样式 */

.page {
  padding-bottom: 20rpx;
}

/* ========== 图片轮播 ========== */
.image-swiper {
  width: 100%;
  height: 600rpx;
}

.swiper-image {
  width: 100%;
  height: 100%;
}

.image-counter {
  position: absolute;
  top: 550rpx;
  right: 24rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 22rpx;
  padding: 6rpx 16rpx;
  border-radius: 20rpx;
}

/* ========== 标题与价格 ========== */
.goods-title-detail {
  font-size: 34rpx;
  font-weight: 600;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 20rpx;
  display: block;
}

.price-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 16rpx;
}

.price {
  font-size: 44rpx;
  font-weight: 700;
  color: var(--danger);
}

.meta-row {
  display: flex;
  flex-wrap: wrap;
  gap: 20rpx;
}

.meta-item {
  font-size: 24rpx;
  color: var(--text-light);
}

/* ========== 章节标题 ========== */
.section-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 18rpx;
  padding-left: 12rpx;
  border-left: 4rpx solid var(--primary);
}

/* ========== 描述 ========== */
.description {
  font-size: 28rpx;
  color: var(--text-secondary);
  line-height: 1.8;
  white-space: pre-wrap;
}

/* ========== 卖家信息 ========== */
.seller-card {
  display: flex;
  align-items: center;
}

.seller-avatar {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  margin-right: 24rpx;
  background: #f0f0f0;
}

.seller-info {
  display: flex;
  flex-direction: column;
}

.seller-name {
  font-size: 30rpx;
  color: var(--text-primary);
  margin-bottom: 8rpx;
}

.seller-contact {
  font-size: 26rpx;
  color: var(--text-secondary);
}

.location-text {
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ========== 底部操作栏 ========== */
.bottom-bar-safe {
  height: 120rpx;
}

.bottom-bar {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  height: 100rpx;
  background: var(--bg-white);
  display: flex;
  align-items: center;
  padding: 0 24rpx;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.06);
  z-index: 100;
}

.bottom-action {
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  padding: 0 20rpx;
  margin-right: 12rpx;
}

.bottom-btn {
  flex: 1;
  height: 72rpx;
  line-height: 72rpx;
  background: #07C160;
  color: #fff;
  text-align: center;
  border-radius: 36rpx;
  font-size: 28rpx;
  margin: 0 8rpx;
}

.contact-btn {
  height: 72rpx;
  line-height: 72rpx;
  padding: 0;
  font-size: 28rpx;
  border: none;
}