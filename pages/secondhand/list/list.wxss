/* 二手商品列表页样式 */

.page {
  padding-bottom: 120rpx;
}

/* ========== 搜索栏 ========== */
.search-bar {
  padding: 16rpx 24rpx;
  background: var(--bg-white);
  border-bottom: 1rpx solid var(--border);
}

.search-input-wrap {
  display: flex;
  align-items: center;
  background: #f5f5f5;
  border-radius: 32rpx;
  padding: 12rpx 24rpx;
}

.search-input {
  flex: 1;
  font-size: 28rpx;
  margin-left: 12rpx;
}

.search-clear {
  font-size: 28rpx;
  color: var(--text-light);
  padding: 0 8rpx;
}

/* ========== 顶部操作栏 ========== */
.top-bar {
  display: flex;
  justify-content: space-between;
  align-items: center;
  padding: 16rpx 24rpx;
  background: var(--bg-white);
}

.search-btn, .sort-btn {
  padding: 10rpx 24rpx;
  background: #f5f5f5;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

/* ========== 排序下拉 ========== */
.sort-menu {
  width: 100%;
  background: var(--bg-white);
  border-bottom: 1rpx solid var(--border);
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.sort-item {
  padding: 24rpx 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
}

.sort-item.active {
  color: var(--primary);
  background: rgba(74, 144, 217, 0.08);
}

/* ========== 分类 Tab ========== */
.tabs {
  display: flex;
  white-space: nowrap;
  padding: 16rpx 24rpx;
  background: var(--bg-white);
  border-bottom: 1rpx solid var(--border);
}

.tab-item {
  display: inline-block;
  padding: 10rpx 28rpx;
  margin-right: 16rpx;
  border-radius: 28rpx;
  font-size: 26rpx;
  color: var(--text-secondary);
  background: #f5f5f5;
  transition: all 0.2s;
}

.tab-item.active {
  color: #07C160;
  background: rgba(7, 193, 96, 0.1);
  font-weight: 600;
}

/* ========== 瀑布流 ========== */
.waterfall {
  display: flex;
  padding: 16rpx;
  gap: 16rpx;
}

.waterfall-column {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

/* ========== 商品卡片 ========== */
.goods-card {
  background: var(--bg-white);
  border-radius: 12rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.goods-img {
  width: 100%;
  display: block;
  min-height: 200rpx;
  background: #f0f0f0;
}

.goods-info {
  padding: 18rpx 16rpx;
}

.goods-title {
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.5;
  margin-bottom: 14rpx;
  min-height: 84rpx;
}

.goods-bottom {
  display: flex;
  justify-content: space-between;
  align-items: center;
  margin-bottom: 10rpx;
}

.goods-price {
  font-size: 32rpx;
  font-weight: 700;
  color: var(--danger);
}

.goods-meta {
  display: flex;
  justify-content: space-between;
  font-size: 22rpx;
  color: var(--text-light);
}

/* ========== 悬浮发布按钮 ========== */
.publish-btn {
  position: fixed;
  bottom: 160rpx;
  right: 40rpx;
  width: 100rpx;
  height: 100rpx;
  background: var(--primary);
  border-radius: 50%;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #fff;
  box-shadow: 0 4rpx 20rpx rgba(74, 144, 217, 0.4);
  z-index: 50;
}

/* ========== 加载提示 ========== */
.loading-tip {
  text-align: center;
  padding: 30rpx 0;
  color: var(--text-light);
  font-size: 24rpx;
}