/* 发布商品页样式 */

.page {
  padding: 20rpx;
  padding-bottom: 20rpx;
}

/* ========== 图片上传 ========== */
.image-list {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 12rpx;
}

.image-item {
  position: relative;
  width: 200rpx;
  height: 200rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.image-preview {
  width: 100%;
  height: 100%;
}

.image-delete {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 40rpx;
  height: 40rpx;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  border-radius: 50%;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 24rpx;
}

.image-add {
  width: 200rpx;
  height: 200rpx;
  border: 2rpx dashed #ccc;
  border-radius: 12rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  color: #ccc;
}

.image-add-icon {
  font-size: 60rpx;
  color: #bbb;
}

.image-add-text {
  font-size: 22rpx;
  color: #bbb;
  margin-top: 8rpx;
}

/* ========== 表单通用 ========== */
.form-label {
  font-size: 28rpx;
  color: var(--text-primary);
  margin-bottom: 12rpx;
  font-weight: 500;
}

.required {
  color: var(--danger);
}

.form-item {
  margin-bottom: 32rpx;
}

.form-item:last-child {
  margin-bottom: 0;
}

.form-input {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  box-sizing: border-box;
}

.form-picker {
  width: 100%;
  height: 80rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  display: flex;
  align-items: center;
  justify-content: space-between;
  box-sizing: border-box;
}

.form-picker.placeholder {
  color: #bbb;
}

.picker-arrow {
  font-size: 36rpx;
  color: #ccc;
}

.price-input-wrap {
  display: flex;
  align-items: center;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding-left: 24rpx;
}

.price-symbol {
  font-size: 32rpx;
  color: var(--danger);
  font-weight: 700;
  margin-right: 8rpx;
}

.price-input {
  flex: 1;
  background: transparent;
  padding-left: 0;
}

.form-textarea {
  width: 100%;
  min-height: 180rpx;
  background: #f8f8f8;
  border-radius: 12rpx;
  padding: 20rpx 24rpx;
  font-size: 28rpx;
  color: var(--text-primary);
  line-height: 1.6;
  box-sizing: border-box;
}

.char-count {
  text-align: right;
  font-size: 22rpx;
  color: var(--text-light);
  margin-top: 8rpx;
}

/* ========== 卡片标题 ========== */
.card-title {
  font-size: 30rpx;
  font-weight: 600;
  color: var(--text-primary);
  margin-bottom: 24rpx;
}

/* ========== 提交按钮 ========== */
.submit-section {
  margin-top: 40rpx;
  padding: 0 10rpx;
}

.submit-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07C160;
  color: #fff;
  border-radius: 44rpx;
  font-size: 30rpx;
  font-weight: 600;
  border: none;
}

.submit-btn.disabled {
  background: #6dd98a;
  opacity: 0.7;
}
