/** pages/index/index.wxss — 首页样式 **/

.page-index {
  min-height: 100vh;
}

/* ===== 搜索栏 ===== */
.search-bar {
  padding: 20rpx 30rpx;
  background-color: var(--color-primary);
}

.search-box {
  display: flex;
  align-items: center;
  background-color: var(--color-white);
  border-radius: 40rpx;
  padding: 12rpx 24rpx;
}

.search-icon {
  margin-right: 12rpx;
  font-size: 30rpx;
}

.search-input {
  flex: 1;
  font-size: 26rpx;
  height: 60rpx;
  line-height: 60rpx;
}

/* ===== 轮播图 ===== */
.banner-section {
  margin: 0 0 20rpx 0;
}

.banner-swiper {
  height: 320rpx;
}

.banner-image {
  width: 100%;
  height: 100%;
}

.banner-title {
  position: absolute;
  bottom: 0;
  left: 0;
  right: 0;
  padding: 16rpx 24rpx;
  background: linear-gradient(transparent, rgba(0,0,0,0.5));
  color: var(--color-white);
  font-size: 28rpx;
}

.banner-placeholder {
  height: 320rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: linear-gradient(135deg, #C8E6C9, #4CAF50);
  color: var(--color-white);
  font-size: 36rpx;
  font-weight: 600;
}

/* ===== 快捷入口 ===== */
.quick-section {
  padding: 0 20rpx;
  margin-bottom: 30rpx;
}

.quick-grid {
  display: flex;
  flex-wrap: wrap;
}

.quick-item {
  width: 25%;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 24rpx 0;
}

.quick-icon {
  font-size: 56rpx;
  margin-bottom: 12rpx;
}

.quick-name {
  font-size: 24rpx;
  color: var(--color-text-secondary);
}

/* ===== 热门推荐 ===== */
.hot-section {
  padding: 0 20rpx 40rpx;
}

.hot-item {
  margin-bottom: 16rpx;
}

.hot-row {
  display: flex;
  align-items: center;
}

.hot-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
}

.hot-thumb-placeholder {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  margin-right: 20rpx;
  flex-shrink: 0;
  background-color: var(--color-bg);
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
}

.hot-info {
  min-width: 0;
}

.hot-title {
  font-size: 30rpx;
  font-weight: 500;
  color: var(--color-text);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
}

.hot-desc {
  font-size: 24rpx;
  color: var(--color-text-light);
  display: block;
  overflow: hidden;
  text-overflow: ellipsis;
  white-space: nowrap;
  margin-top: 8rpx;
}

.hot-meta {
  display: flex;
  align-items: center;
  margin-top: 12rpx;
}

.hot-tag {
  font-size: 22rpx;
  padding: 4rpx 12rpx;
  border-radius: 6rpx;
  margin-right: 16rpx;
}

.tag-goods {
  background-color: #FFF3E0;
  color: #FF9800;
}

.tag-lost {
  background-color: #E3F2FD;
  color: #2196F3;
}

.hot-price {
  font-size: 30rpx;
  color: var(--color-danger);
  font-weight: 600;
}

/* ===== 收藏星标 ===== */
.fav-star {
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-left: 12rpx;
  font-size: 38rpx;
}

/* ===== 骨架屏 ===== */
.skeleton {
  padding: 0;
}

.sk-banner {
  height: 320rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f0f0f0 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-quick-grid {
  display: flex;
  padding: 30rpx 20rpx;
  justify-content: space-around;
}

.sk-quick-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.sk-circle {
  width: 80rpx;
  height: 80rpx;
  border-radius: 50%;
  background: linear-gradient(90deg, #e8e8e8 25%, #f0f0f0 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-text-short {
  width: 80rpx;
  height: 24rpx;
  border-radius: 6rpx;
  margin-top: 14rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f0f0f0 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  margin: 0 20rpx 16rpx;
  background: #fff;
  border-radius: 16rpx;
}

.sk-thumb {
  width: 140rpx;
  height: 140rpx;
  border-radius: 12rpx;
  flex-shrink: 0;
  margin-right: 20rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f0f0f0 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-lines {
  flex: 1;
  display: flex;
  flex-direction: column;
  gap: 16rpx;
}

.sk-line {
  height: 24rpx;
  border-radius: 6rpx;
  background: linear-gradient(90deg, #e8e8e8 25%, #f0f0f0 50%, #e8e8e8 75%);
  background-size: 200% 100%;
  animation: shimmer 1.5s infinite;
}

.sk-line.w80 { width: 80%; }
.sk-line.w60 { width: 60%; }
.sk-line.w40 { width: 40%; }

@keyframes shimmer {
  0%   { background-position: 200% 0; }
  100% { background-position: -200% 0; }
}

/* ===== 分类标签 ===== */
.category-section {
  padding: 0 20rpx;
}

.category-scroll {
  white-space: nowrap;
}

.category-tags {
  display: inline-flex;
  gap: 16rpx;
  padding: 10rpx 0 20rpx;
}

.category-tag {
  display: inline-flex;
  align-items: center;
  padding: 16rpx 28rpx;
  background: var(--color-white);
  border-radius: 40rpx;
  font-size: 26rpx;
  color: var(--color-text);
  box-shadow: 0 2rpx 12rpx rgba(0,0,0,0.04);
  flex-shrink: 0;
}
