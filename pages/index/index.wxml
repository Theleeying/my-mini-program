<!--pages/index/index.wxml — 首页-->
<view class="page-index">

  <!-- 顶部搜索栏 -->
  <view class="search-bar">
    <view class="search-box">
      <text class="search-icon">🔍</text>
      <input
        class="search-input"
        type="text"
        placeholder="搜索二手商品或失物信息..."
        value="{{searchKeyword}}"
        bindinput="onSearchInput"
        bindconfirm="onSearch"
      />
    </view>
  </view>

  <!-- 骨架屏 -->
  <view wx:if="{{loading}}" class="skeleton">
    <view class="sk-banner"></view>
    <view class="sk-quick-grid">
      <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="sk-quick-item">
        <view class="sk-circle"></view>
        <view class="sk-text-short"></view>
      </view>
    </view>
    <view class="section-title">🔥 热门推荐</view>
    <view wx:for="{{[1,2,3,4]}}" wx:key="*this" class="sk-card">
      <view class="sk-thumb"></view>
      <view class="sk-lines">
        <view class="sk-line w80"></view>
        <view class="sk-line w60"></view>
        <view class="sk-line w40"></view>
      </view>
    </view>
  </view>

  <!-- 实际内容（非骨架屏） -->
  <view wx:else>
  <!-- 轮播图 -->
  <view class="banner-section">
    <swiper
      class="banner-swiper"
      indicator-dots="{{banners.length > 1}}"
      indicator-color="rgba(255,255,255,0.5)"
      indicator-active-color="#4CAF50"
      autoplay="{{banners.length > 1}}"
      circular="{{banners.length > 1}}"
      interval="4000"
    >
      <block wx:for="{{banners}}" wx:key="_id">
        <swiper-item data-id="{{item._id}}" bindtap="onBannerTap">
          <image class="banner-image" src="{{item.image}}" mode="aspectFill" />
          <view class="banner-title">{{item.title}}</view>
        </swiper-item>
      </block>
    </swiper>
    <!-- 无轮播图时的占位 -->
    <view wx:if="{{banners.length === 0}}" class="banner-placeholder">
      <text>🏫 欢迎使用校易通</text>
    </view>
  </view>

  <!-- 快捷入口 -->
  <view class="quick-section">
    <view class="section-title">快捷服务</view>
    <view class="quick-grid">
      <view
        wx:for="{{quickEntries}}"
        wx:key="name"
        class="quick-item"
        data-url="{{item.url}}"
        bindtap="onQuickEntry"
      >
        <text class="quick-icon">{{item.icon}}</text>
        <text class="quick-name">{{item.name}}</text>
      </view>
    </view>
  </view>

  <!-- 热门推荐 -->
  <view class="hot-section">
    <view class="section-title">🔥 热门推荐</view>

    <view wx:if="{{hotList.length === 0}}" class="empty-state">
      <text>暂无推荐内容</text>
    </view>

    <view
      wx:for="{{hotList}}"
      wx:key="_id"
      class="hot-item card"
      data-item="{{item}}"
      bindtap="onTapRecommend"
    >
      <view class="hot-row">
        <image wx:if="{{item.images && item.images.length}}" class="hot-thumb" src="{{item.images[0]}}" mode="aspectFill" />
        <view wx:else class="hot-thumb-placeholder">
          <text>{{item.__type === 'goods' ? '📦' : '🎯'}}</text>
        </view>
        <view class="hot-info flex-1">
          <text class="hot-title">{{item.title}}</text>
          <text class="hot-desc">{{item.description || ''}}</text>
          <view class="hot-meta">
            <text class="hot-tag {{item.__type === 'goods' ? 'tag-goods' : 'tag-lost'}}">
              {{item.__type === 'goods' ? '二手' : '失物'}}
            </text>
            <text wx:if="{{item.__type === 'goods' && item.price}}" class="hot-price">¥{{item.price}}</text>
          </view>
        </view>
        <!-- 收藏星标 -->
        <view
          class="fav-star"
          data-id="{{item._id}}"
          data-type="{{item.__type}}"
          catchtap="onToggleFavorite"
        >
          <text>{{item.isFavorited ? '⭐' : '☆'}}</text>
        </view>
      </view>
    </view>
  </view>
  </view>

</view>
